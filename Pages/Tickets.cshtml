@page
@model customer_wellness_project.Pages.TicketsModel
@{
    Layout = "_PortalLayout";
    ViewData["Title"] = "Tickets";
    ViewData["ActivePage"] = "Tickets";
}

<div class="mb-10 flex justify-between items-end animate-[fade-in_0.5s_ease-out]">
    <div>
        <span class="text-[0.75rem] font-bold uppercase tracking-[0.05em] text-[#515f74] mb-2 block">Resolution Center</span>
        <h2 class="text-[2.5rem] font-bold tracking-tight text-slate-900">Clinical Support Tickets</h2>
    </div>
    <div class="flex gap-3">
        <button onclick="showToast('New Ticket', 'Opening support ticket wizard...', 'add_box')" class="px-5 py-2.5 rounded-xl text-sm font-semibold text-white bg-gradient-to-br from-[#3d6846] to-[#7ca982] shadow-md hover:shadow-lg transition-all flex items-center gap-2">
            <span class="material-symbols-outlined text-sm">add</span>
            Create Ticket
        </button>
    </div>
</div>

<div class="bg-white rounded-xl shadow-[0_20px_40px_rgba(51,65,85,0.04)] border border-slate-100 overflow-hidden animate-[fade-in-up_0.6s_ease-out]">
    @if (!Model.Tickets.Any())
    {
        <div class="p-12 flex flex-col items-center justify-center text-center">
            <span class="material-symbols-outlined text-6xl text-slate-200 mb-4">confirmation_number</span>
            <h3 class="text-xl font-bold text-slate-700 mb-2">No Open Tickets</h3>
            <p class="text-slate-500 max-w-sm text-center">Your clinical network is operating smoothly with zero active incidents.</p>
        </div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-100 text-xs uppercase tracking-wider text-slate-500 font-semibold">
                        <th class="p-4 pl-6">Support Request</th>
                        <th class="p-4">Related Product</th>
                        <th class="p-4">Priority</th>
                        <th class="p-4">Status</th>
                        <th class="p-4 pr-6 text-right">Age</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-sm">
                    @foreach (var ticket in Model.Tickets)
                    {
                        var priorityColorClass = ticket.Priority == "Urgent" ? "bg-red-50 text-red-700 border-red-200" 
                                               : ticket.Priority == "Normal" ? "bg-amber-50 text-amber-700 border-amber-200" 
                                               : "bg-slate-50 text-slate-700 border-slate-200";

                        var statusColorClass = ticket.Status == "Open" ? "text-orange-600" 
                                             : ticket.Status == "In Progress" ? "text-blue-600" 
                                             : "text-emerald-600";

                        <tr class="hover:bg-slate-50/50 transition-colors group cursor-pointer" onclick="showToast('Ticket Details', '@Html.Raw(ticket.Title.Replace("'", "\\'"))', 'visibility')">
                            <td class="p-4 pl-6">
                                <p class="font-bold text-slate-800">@ticket.Title</p>
                                <p class="text-xs text-slate-500 truncate max-w-sm mt-0.5">@ticket.Description</p>
                            </td>
                            <td class="p-4">
                                @if (ticket.Product != null)
                                {
                                    <span class="text-sm font-medium text-slate-700">@ticket.Product.Name <span class="text-xs text-slate-400 font-mono">(@ticket.Product.SKU)</span></span>
                                }
                                else
                                {
                                    <span class="text-xs text-slate-400 italic">General Facility</span>
                                }
                            </td>
                            <td class="p-4">
                                <span class="inline-flex items-center px-2.5 py-1 rounded-md text-[10px] font-bold uppercase tracking-wider border @priorityColorClass">
                                    @ticket.Priority
                                </span>
                            </td>
                            <td class="p-4">
                                <div class="flex items-center gap-2 @statusColorClass">
                                    <span class="material-symbols-outlined text-[16px]">
                                        @(ticket.Status == "Open" ? "error_circle_rounded" : ticket.Status == "In Progress" ? "pending" : "check_circle")
                                    </span>
                                    <span class="font-bold text-xs uppercase tracking-wider">@ticket.Status</span>
                                </div>
                            </td>
                            <td class="p-4 pr-6 text-right text-xs text-slate-500">
                                @((DateTime.UtcNow - ticket.CreatedAt).Days > 0 ? (DateTime.UtcNow - ticket.CreatedAt).Days + " day(s) ago" : "Today")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    @@keyframes fade-in { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes fade-in-up { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
</style>
