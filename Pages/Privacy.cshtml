@page
@{
    Layout = null;
    ViewData["Title"] = "Privacy Policy & Legal";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="bg-slate-50 font-sans p-10">
    <div class="max-w-3xl mx-auto bg-white p-12 rounded-2xl shadow-sm border border-slate-100">
        <h1 class="text-3xl font-bold mb-6 text-slate-800">Legal Information</h1>
        <div class="prose prose-slate">
            <p class="mb-4 text-slate-600">This is a placeholder page for the WellnessOps Privacy Policy, Terms of Service, and HIPAA Compliance details.</p>
            <p class="mb-4 text-slate-600">All data entered into this demonstration application is completely mocked and not transmitted to external third parties.</p>
            <a asp-page="/Index" class="text-emerald-600 font-semibold hover:underline mt-8 inline-block">&larr; Return to Home</a>
        </div>
    </div>
</body>
</html>
