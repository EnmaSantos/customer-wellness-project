@page
@model customer_wellness_project.Pages.UserProfileModel
@{
    Layout = "_PortalLayout";
    ViewData["Title"] = "User Profile";
    ViewData["ActivePage"] = "Dashboard";
}

<header class="mb-10 animate-[fade-in_0.5s_ease-out]">
    <h1 class="text-4xl font-bold tracking-tight font-headline text-on-surface mb-2">Account Settings</h1>
    <p class="text-on-surface-variant font-body">Manage your clinical profile and preferences.</p>
</header>

<div class="grid grid-cols-1 md:grid-cols-12 gap-6 items-start animate-[fade-in-up_0.6s_ease-out]">
    <!-- Profile Card -->
    <div class="md:col-span-7 bg-white p-8 rounded-lg shadow-sm border border-slate-100 hover:-translate-y-1 hover:shadow-md transition-all">
        <div class="flex flex-col sm:flex-row items-center gap-8">
            <div class="relative group">
                <img alt="Profile avatar" class="w-32 h-32 rounded-full border-4 border-emerald-100 shadow-md" src="https://lh3.googleusercontent.com/aida-public/AB6AXuB8GiH8fy5sFfWGxe5u1Zz0n136FEFTn9ODwMRzHGI6dBJEFqMNYGvneAuz2EJt-O2tyNhmbQPPp8fUMn2kOege7Ue3O50Lndd2Bp71gb-xbngKEmN6GAXxa_7ZoeixsPddUt2M-RPYF8beGHEzw_e1FiFvalxUyEALFF7aslSvlA9p083_rspXXzvovmnHAFtsvxb2DNBaWsfHYg54qH7GQv0hQ_f5eancs5h0Zaif1gtzx9eppE86FJ5kSyIpj8sUpxdhTqPGHfIH" />
                <button onclick="showToast('Upload Avatar', 'The image upload wizard will be available soon.', 'upload_file')" class="absolute bottom-1 right-1 bg-[#3d6846] text-white p-2 rounded-full shadow-lg hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined text-sm">edit</span>
                </button>
            </div>
            <div class="text-center sm:text-left">
                <span class="text-[10px] font-bold tracking-[0.1em] text-[#515f74] uppercase bg-slate-100 px-2 py-1 rounded">Medical Administrator</span>
                <h2 class="text-3xl font-bold text-slate-800 mt-2 font-headline">Dr. Sarah Henderson</h2>
                <p class="text-slate-500 mb-4">Senior Clinical Operations Manager</p>
                <div class="flex flex-wrap gap-3 justify-center sm:justify-start">
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700">
                        <span class="w-2 h-2 rounded-full bg-emerald-500 mr-2"></span> Active Now
                    </span>
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-slate-100 text-slate-600">
                        ID: #ADMIN-9921
                    </span>
                </div>
            </div>
        </div>
        <div class="grid grid-cols-2 gap-4 mt-8 pt-8 border-t border-slate-100">
            <div>
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Email Address</p>
                <p class="text-sm font-medium">s.henderson@wellnessops.clinic</p>
            </div>
            <div>
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Department</p>
                <p class="text-sm font-medium">Cardiology Diagnostics</p>
            </div>
        </div>
    </div>

    <!-- Activity Stats Card -->
    <div class="md:col-span-5 bg-white p-8 rounded-lg shadow-sm border border-slate-100 hover:-translate-y-1 hover:shadow-md transition-all flex flex-col justify-between min-h-[300px]">
        <div class="flex justify-between items-center mb-6">
            <h3 class="text-lg font-semibold text-slate-800 font-headline">Activity Stats</h3>
            <span class="material-symbols-outlined text-slate-400 opacity-50">query_stats</span>
        </div>
        <div class="space-y-6">
            <div>
                <div class="flex justify-between mb-2">
                    <span class="text-sm font-medium text-slate-500">Profile Completion</span>
                    <span class="text-sm font-bold text-[#3d6846]">85%</span>
                </div>
                <div class="h-2 bg-slate-100 rounded-full overflow-hidden">
                    <div class="h-full bg-gradient-to-r from-[#3d6846] to-[#7ca982]" style="width: 85%"></div>
                </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div class="p-4 rounded-xl bg-slate-50 border border-slate-100">
                    <p class="text-2xl font-bold text-slate-800">1,240</p>
                    <p class="text-xs text-slate-500">Records Reviewed</p>
                </div>
                <div class="p-4 rounded-xl bg-slate-50 border border-slate-100">
                    <p class="text-2xl font-bold text-slate-800">42</p>
                    <p class="text-xs text-slate-500">Clinical Reports</p>
                </div>
            </div>
        </div>
        <button onclick="showToast('Analytics', 'Fetching detailed compliance reports...', 'analytics')" class="mt-6 text-sm font-semibold text-[#3d6846] flex items-center gap-2 group cursor-pointer w-fit">
            View detailed analytics <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
        </button>
    </div>

    <!-- Account Preferences Card -->
    <div class="md:col-span-5 bg-white p-8 rounded-lg shadow-sm border border-slate-100 hover:-translate-y-1 hover:shadow-md transition-all">
        <div class="flex items-center gap-3 mb-8">
            <div class="p-2 bg-emerald-50 text-emerald-700 rounded-lg">
                <span class="material-symbols-outlined">security_update_good</span>
            </div>
            <h3 class="text-lg font-semibold text-slate-800 font-headline">Account Preferences</h3>
        </div>
        <div class="space-y-6">
            <div onclick="showToast('Security', 'Security settings modal opening...', 'lock')" class="flex items-center justify-between p-3 hover:bg-slate-50 rounded-lg transition-colors cursor-pointer group">
                <div class="flex items-center gap-4">
                    <span class="material-symbols-outlined text-slate-400">lock</span>
                    <div>
                        <p class="text-sm font-semibold">Security &amp; Access</p>
                        <p class="text-xs text-slate-500">Two-factor authentication active</p>
                    </div>
                </div>
                <span class="material-symbols-outlined text-slate-300 group-hover:text-[#3d6846] transition-colors">chevron_right</span>
            </div>
            <div onclick="showToast('Language', 'Language configuration loading...', 'language')" class="flex items-center justify-between p-3 hover:bg-slate-50 rounded-lg transition-colors cursor-pointer group">
                <div class="flex items-center gap-4">
                    <span class="material-symbols-outlined text-slate-400">language</span>
                    <div>
                        <p class="text-sm font-semibold">Language &amp; Region</p>
                        <p class="text-xs text-slate-500">English (US) - PST Timezone</p>
                    </div>
                </div>
                <span class="material-symbols-outlined text-slate-300 group-hover:text-[#3d6846] transition-colors">chevron_right</span>
            </div>
            <div onclick="showToast('Privacy', 'Privacy configurations loaded.', 'visibility')" class="flex items-center justify-between p-3 hover:bg-slate-50 rounded-lg transition-colors cursor-pointer group">
                <div class="flex items-center gap-4">
                    <span class="material-symbols-outlined text-slate-400">visibility</span>
                    <div>
                        <p class="text-sm font-semibold">Privacy Settings</p>
                        <p class="text-xs text-slate-500">Profile visible to Clinical Staff</p>
                    </div>
                </div>
                <span class="material-symbols-outlined text-slate-300 group-hover:text-[#3d6846] transition-colors">chevron_right</span>
            </div>
        </div>
        <button onclick="showToast('Saved', 'Your preferences have been successfully updated across all linked devices.', 'cloud_done')" class="mt-8 w-full py-3 border-2 border-[#3d6846]/20 text-[#3d6846] rounded-xl font-semibold hover:bg-[#3d6846]/5 transition-colors">
            Update All Preferences
        </button>
    </div>

    <!-- Notification History Card -->
    <div class="md:col-span-7 bg-white p-8 rounded-lg shadow-sm border border-slate-100 hover:-translate-y-1 hover:shadow-md transition-all h-full">
        <div class="flex justify-between items-center mb-8">
            <h3 class="text-lg font-semibold text-slate-800 font-headline">Notification History</h3>
            <button onclick="showToast('Read', 'All notifications marked as read', 'done_all')" class="text-xs font-bold text-slate-500 uppercase tracking-widest hover:text-[#3d6846] transition-colors">Mark all as read</button>
        </div>
        <div class="space-y-4">
            <div class="flex gap-4 p-4 rounded-xl bg-emerald-50 border-l-4 border-emerald-500">
                <div class="flex-shrink-0 mt-1">
                    <span class="material-symbols-outlined text-emerald-600">verified_user</span>
                </div>
                <div class="flex-1">
                    <div class="flex justify-between items-start">
                        <p class="text-sm font-bold text-slate-800">Security Audit Completed</p>
                        <span class="text-[10px] text-slate-500 font-medium">2m ago</span>
                    </div>
                    <p class="text-xs text-slate-600 mt-1">Your quarterly access review has been finalized. No issues found.</p>
                </div>
            </div>
            <div class="flex gap-4 p-4 rounded-xl hover:bg-slate-50 transition-colors">
                <div class="flex-shrink-0 mt-1">
                    <span class="material-symbols-outlined text-slate-400">medical_services</span>
                </div>
                <div class="flex-1">
                    <div class="flex justify-between items-start">
                        <p class="text-sm font-semibold text-slate-800">New Health Log Entry</p>
                        <span class="text-[10px] text-slate-500 font-medium">1h ago</span>
                    </div>
                    <p class="text-xs text-slate-600 mt-1">Patient #8829 biometric data updated by Dr. Miller.</p>
                </div>
            </div>
            <div class="flex gap-4 p-4 rounded-xl hover:bg-slate-50 transition-colors">
                <div class="flex-shrink-0 mt-1">
                    <span class="material-symbols-outlined text-slate-400">update</span>
                </div>
                <div class="flex-1">
                    <div class="flex justify-between items-start">
                        <p class="text-sm font-semibold text-slate-800">System Maintenance</p>
                        <span class="text-[10px] text-slate-500 font-medium">5h ago</span>
                    </div>
                    <p class="text-xs text-slate-600 mt-1">The clinical portal will be offline for 15 minutes at 02:00 AM PST.</p>
                </div>
            </div>
            <div class="flex gap-4 p-4 rounded-xl hover:bg-slate-50 transition-colors">
                <div class="flex-shrink-0 mt-1">
                    <span class="material-symbols-outlined text-slate-400">mail</span>
                </div>
                <div class="flex-1">
                    <div class="flex justify-between items-start">
                        <p class="text-sm font-semibold text-slate-800">Compliance Report Ready</p>
                        <span class="text-[10px] text-slate-500 font-medium">Yesterday</span>
                    </div>
                    <p class="text-xs text-slate-600 mt-1">The HIPAA compliance summary for Q3 is now available for download.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@keyframes fade-in { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes fade-in-up { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
</style>
