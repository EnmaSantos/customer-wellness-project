@page
@model customer_wellness_project.Pages.InventoryModel
@{
    Layout = "_PortalLayout";
    ViewData["Title"] = "Inventory";
    ViewData["ActivePage"] = "Inventory";
}

<!-- Page Header -->
<div class="mb-10 flex justify-between items-end animate-[fade-in_0.5s_ease-out]">
    <div>
        <span class="text-[0.75rem] font-bold uppercase tracking-[0.05em] text-[#515f74] mb-2 block">Clinical Assets</span>
        <h2 class="text-[2.5rem] font-bold tracking-tight text-slate-900">Inventory Management</h2>
    </div>
    <div class="flex gap-3">
        <button onclick="showToast('Export', 'Preparing CSV export...', 'download')" class="px-5 py-2.5 rounded-xl text-sm font-semibold text-slate-600 bg-white border border-slate-200 shadow-sm hover:bg-slate-50 transition-all">
            Export List
        </button>
        <button onclick="showToast('Reorder', 'Drafting automated reorder requests...', 'shopping_cart')" class="px-5 py-2.5 rounded-xl text-sm font-semibold text-white bg-gradient-to-br from-[#3d6846] to-[#7ca982] shadow-md hover:shadow-lg transition-all flex items-center gap-2">
            <span class="material-symbols-outlined text-sm">add_shopping_cart</span>
            Auto-Reorder
        </button>
    </div>
</div>

<div class="bg-white rounded-xl shadow-[0_20px_40px_rgba(51,65,85,0.04)] border border-slate-100 overflow-hidden animate-[fade-in-up_0.6s_ease-out]">
    @if (!Model.Products.Any())
    {
        <div class="p-12 flex flex-col items-center justify-center text-center">
            <span class="material-symbols-outlined text-6xl text-slate-200 mb-4">inventory_2</span>
            <h3 class="text-xl font-bold text-slate-700 mb-2">No Products Found</h3>
            <p class="text-slate-500 max-w-sm text-center">Your clinical inventory seems empty. Add products to populate this datagrid.</p>
        </div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-100 text-xs uppercase tracking-wider text-slate-500 font-semibold">
                        <th class="p-4 pl-6">Product Information</th>
                        <th class="p-4">Category</th>
                        <th class="p-4">Stock Status</th>
                        <th class="p-4 pr-6 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-sm">
                    @foreach (var item in Model.Products)
                    {
                        <tr class="hover:bg-slate-50/50 transition-colors group">
                            <td class="p-4 pl-6">
                                <p class="font-bold text-slate-800">@item.Name</p>
                                <p class="text-xs text-slate-500 font-mono mt-0.5">@item.SKU</p>
                            </td>
                            <td class="p-4">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-600">
                                    @item.Category
                                </span>
                            </td>
                            <td class="p-4">
                                @if (item.StockQuantity < item.MinimumThreshold)
                                {
                                    <div class="flex items-center gap-2 text-red-600 bg-red-50 w-fit px-3 py-1.5 rounded-lg border border-red-100">
                                        <span class="material-symbols-outlined text-[16px]">warning</span>
                                        <span class="font-bold">@item.StockQuantity</span>
                                        <span class="text-xs text-red-400 font-medium">(Min: @item.MinimumThreshold)</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="flex items-center gap-2 text-emerald-600 bg-emerald-50 w-fit px-3 py-1.5 rounded-lg border border-emerald-100">
                                        <span class="material-symbols-outlined text-[16px]">check_circle</span>
                                        <span class="font-bold">@item.StockQuantity</span>
                                        <span class="text-xs text-emerald-400 font-medium uppercase tracking-wider">Optimal</span>
                                    </div>
                                }
                            </td>
                            <td class="p-4 pr-6 text-right">
                                <button onclick="showToast('Edit', 'Opening product editor for @item.Name', 'edit')" class="text-slate-400 hover:text-[#3d6846] transition-colors p-2">
                                    <span class="material-symbols-outlined text-[20px]">edit</span>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    @@keyframes fade-in { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes fade-in-up { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
</style>
