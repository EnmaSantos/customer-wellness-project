@page
@model customer_wellness_project.Pages.SignUpModel
@{
    Layout = null;
    ViewData["Title"] = "Join WellnessOps | Clinical Registration";
}

<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "surface": "#f7f9fb",
                        "on-secondary-fixed": "#0d1c2f",
                        "error-container": "#ffdad6",
                        "on-error": "#ffffff",
                        "on-tertiary-container": "#26364b",
                        "on-error-container": "#93000a",
                        "on-tertiary-fixed": "#0b1c30",
                        "inverse-primary": "#a3d2a8",
                        "tertiary-fixed": "#d3e4fe",
                        "error": "#ba1a1a",
                        "on-tertiary-fixed-variant": "#38485d",
                        "outline": "#727970",
                        "surface-container-lowest": "#ffffff",
                        "surface-container-high": "#e6e8ea",
                        "tertiary": "#505f76",
                        "secondary": "#515f74",
                        "primary-fixed": "#bfeec3",
                        "on-primary-fixed-variant": "#254f30",
                        "primary-fixed-dim": "#a3d2a8",
                        "on-surface": "#191c1e",
                        "surface-container-low": "#f2f4f6",
                        "primary-container": "#7ca982",
                        "on-secondary-container": "#57657b",
                        "surface-container": "#eceef0",
                        "tertiary-fixed-dim": "#b7c8e1",
                        "tertiary-container": "#8f9fb8",
                        "outline-variant": "#c1c9bf",
                        "on-tertiary": "#ffffff",
                        "surface-container-highest": "#e0e3e5",
                        "on-primary": "#ffffff",
                        "on-secondary": "#ffffff",
                        "surface-variant": "#e0e3e5",
                        "surface-tint": "#3d6846",
                        "secondary-fixed-dim": "#b9c7e0",
                        "surface-bright": "#f7f9fb",
                        "background": "#f7f9fb",
                        "secondary-container": "#d5e3fd",
                        "primary": "#3d6846",
                        "on-secondary-fixed-variant": "#3a485c",
                        "secondary-fixed": "#d5e3fd",
                        "on-primary-fixed": "#00210b",
                        "inverse-surface": "#2d3133",
                        "on-surface-variant": "#414941",
                        "on-primary-container": "#133d20",
                        "on-background": "#191c1e",
                        "inverse-on-surface": "#eff1f3",
                        "surface-dim": "#d8dadc"
                    },
                    fontFamily: {
                        "headline": ["Inter"],
                        "body": ["Inter"],
                        "label": ["Inter"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .cta-gradient {
            background: linear-gradient(135deg, #3d6846 0%, #7ca982 100%);
        }
        .glass-nav {
            background: rgba(247, 249, 251, 0.8);
            backdrop-filter: blur(20px);
        }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #eceef0; border-radius: 10px; }
    </style>
</head>
<body class="bg-surface text-on-surface min-h-screen flex flex-col">
    <!-- Top Navigation -->
    <header class="fixed top-0 w-full z-50 glass-nav shadow-[0_20px_40px_rgba(51,65,85,0.04)]">
        <div class="max-w-7xl mx-auto px-8 h-16 flex justify-between items-center">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;">spa</span>
                <span class="text-xl font-extrabold text-primary tracking-tight">WellnessOps</span>
            </div>
            <div class="hidden md:flex items-center gap-6">
                <span class="text-label-md font-bold text-secondary tracking-widest uppercase text-xs">Clinical Portal Registration</span>
                <div class="h-4 w-[1px] bg-outline-variant/30"></div>
                <a class="text-body-md text-on-surface-variant hover:text-primary transition-colors duration-200" asp-page="/Login">Already have an account? Log in</a>
            </div>
        </div>
    </header>

    <main class="flex-grow pt-32 pb-20 px-4 flex items-center justify-center">
        <div class="max-w-5xl w-full grid grid-cols-1 lg:grid-cols-12 gap-8">
            <!-- Left Side: Editorial Context -->
            <div class="lg:col-span-4 space-y-6">
                <div class="p-8 rounded-xl bg-surface-container-low flex flex-col justify-between h-full min-h-[400px]">
                    <div>
                        <span class="inline-block px-3 py-1 rounded-full bg-primary-fixed text-on-primary-fixed-variant text-[10px] font-bold tracking-widest uppercase mb-6">Security First</span>
                        <h1 class="text-headline-sm font-semibold text-secondary leading-tight mb-4">Establishing Your Clinical Presence</h1>
                        <p class="text-body-md text-on-surface-variant leading-relaxed">Join a network of elite practitioners utilizing HIPAA-compliant infrastructure to deliver superior patient outcomes.</p>
                    </div>
                    <div class="mt-8 space-y-6">
                        <div class="flex items-start gap-4">
                            <div class="w-10 h-10 rounded-lg bg-surface-container-lowest flex items-center justify-center flex-shrink-0 shadow-sm">
                                <span class="material-symbols-outlined text-primary">verified_user</span>
                            </div>
                            <div>
                                <p class="text-sm font-bold text-secondary">Verified Credentials</p>
                                <p class="text-xs text-on-surface-variant">Automated NPI and medical license validation.</p>
                            </div>
                        </div>
                        <div class="flex items-start gap-4">
                            <div class="w-10 h-10 rounded-lg bg-surface-container-lowest flex items-center justify-center flex-shrink-0 shadow-sm">
                                <span class="material-symbols-outlined text-primary">encrypted</span>
                            </div>
                            <div>
                                <p class="text-sm font-bold text-secondary">End-to-End Encryption</p>
                                <p class="text-xs text-on-surface-variant">Your data and patient records are strictly protected.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Side: Registration Form -->
            <div class="lg:col-span-8">
                <div class="bg-surface-container-lowest rounded-xl shadow-[0_20px_40px_rgba(51,65,85,0.04)] p-8 md:p-12 overflow-hidden relative">
                    <!-- Progress Indicator -->
                    <nav aria-label="Progress" class="mb-12">
                        <ol class="flex items-center" role="list">
                            <li class="relative flex-1">
                                <div class="group flex flex-col items-center">
                                    <span class="flex h-10 w-10 items-center justify-center rounded-full cta-gradient text-white ring-8 ring-surface-container-lowest relative z-10">
                                        <span class="material-symbols-outlined text-xl" style="font-variation-settings: 'FILL' 1;">person</span>
                                    </span>
                                    <span class="absolute top-5 left-1/2 w-full h-0.5 bg-primary-fixed -translate-y-1/2"></span>
                                    <span class="mt-4 text-[10px] font-bold text-primary tracking-widest uppercase">Professional Info</span>
                                </div>
                            </li>
                            <li class="relative flex-1">
                                <div class="group flex flex-col items-center">
                                    <span class="flex h-10 w-10 items-center justify-center rounded-full bg-surface-container-high text-on-surface-variant ring-8 ring-surface-container-lowest relative z-10">
                                        <span class="material-symbols-outlined text-xl">domain</span>
                                    </span>
                                    <span class="absolute top-5 left-1/2 w-full h-0.5 bg-surface-container-high -translate-y-1/2"></span>
                                    <span class="mt-4 text-[10px] font-bold text-on-surface-variant tracking-widest uppercase">Facility Details</span>
                                </div>
                            </li>
                            <li class="relative">
                                <div class="group flex flex-col items-center">
                                    <span class="flex h-10 w-10 items-center justify-center rounded-full bg-surface-container-high text-on-surface-variant ring-8 ring-surface-container-lowest relative z-10">
                                        <span class="material-symbols-outlined text-xl">how_to_reg</span>
                                    </span>
                                    <span class="mt-4 text-[10px] font-bold text-on-surface-variant tracking-widest uppercase">Verification</span>
                                </div>
                            </li>
                        </ol>
                    </nav>

                    <!-- Form Content -->
                    <div class="space-y-8">
                        <div>
                            <h2 class="text-xl font-semibold text-secondary mb-2">Primary Practitioner Profile</h2>
                            <p class="text-body-md text-on-surface-variant">Please provide your legal medical credentials as they appear on your state license.</p>
                        </div>

                        <form method="post" class="space-y-6">
                            @Html.AntiForgeryToken()

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="space-y-2">
                                    <label class="block text-[10px] font-bold text-secondary tracking-widest uppercase ml-1">Full Legal Name</label>
                                    <input asp-for="FullName" class="w-full bg-surface-container-high border-none rounded-lg px-4 py-3 text-on-surface focus:ring-2 focus:ring-primary focus:bg-surface-container-lowest transition-all duration-200" placeholder="Dr. Julian Sterling" type="text" />
                                </div>
                                <div class="space-y-2">
                                    <label class="block text-[10px] font-bold text-secondary tracking-widest uppercase ml-1">Medical Specialty</label>
                                    <select asp-for="Specialty" class="w-full bg-surface-container-high border-none rounded-lg px-4 py-3 text-on-surface focus:ring-2 focus:ring-primary focus:bg-surface-container-lowest transition-all duration-200">
                                        <option value="">Select a specialty</option>
                                        @foreach (var specialty in Model.Specialties)
                                        {
                                            <option value="@specialty">@specialty</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="space-y-2">
                                    <label class="block text-[10px] font-bold text-secondary tracking-widest uppercase ml-1">NPI Number</label>
                                    <input asp-for="NpiNumber" class="w-full bg-surface-container-high border-none rounded-lg px-4 py-3 text-on-surface focus:ring-2 focus:ring-primary focus:bg-surface-container-lowest transition-all duration-200" placeholder="10-digit identifier" type="text" />
                                </div>
                                <div class="space-y-2">
                                    <label class="block text-[10px] font-bold text-secondary tracking-widest uppercase ml-1">License State</label>
                                    <input asp-for="LicenseState" class="w-full bg-surface-container-high border-none rounded-lg px-4 py-3 text-on-surface focus:ring-2 focus:ring-primary focus:bg-surface-container-lowest transition-all duration-200" placeholder="e.g. California" type="text" />
                                </div>
                            </div>

                            <div class="space-y-2">
                                <label class="block text-[10px] font-bold text-secondary tracking-widest uppercase ml-1">Clinical Email Address</label>
                                <input asp-for="Email" class="w-full bg-surface-container-high border-none rounded-lg px-4 py-3 text-on-surface focus:ring-2 focus:ring-primary focus:bg-surface-container-lowest transition-all duration-200" placeholder="julian.sterling@@wellnessops.clinic" type="email" />
                            </div>

                            <div class="pt-8 flex justify-between items-center">
                                <button class="px-6 py-3 text-sm font-semibold text-on-surface-variant hover:text-primary transition-colors duration-200" type="button">Save for later</button>
                                <button class="cta-gradient text-white px-10 py-4 rounded-xl font-bold flex items-center gap-2 shadow-lg shadow-primary-container/20 active:scale-95 transition-transform duration-200" type="submit">
                                    Continue to Facility Details
                                    <span class="material-symbols-outlined">arrow_forward</span>
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- Decorative Element -->
                    <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-primary-fixed-dim/10 rounded-full blur-3xl"></div>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="mt-auto w-full border-t-0">
        <div class="max-w-7xl mx-auto px-8 py-12 flex flex-col md:flex-row justify-between items-center gap-6">
            <div class="flex flex-col gap-1">
                <p class="font-bold text-slate-900 text-sm">WellnessOps Clinical Systems</p>
                <p class="text-xs text-slate-500">&copy; @DateTime.Now.Year WellnessOps Clinical Systems. All rights reserved.</p>
            </div>
            <div class="flex gap-8">
                <a class="text-xs text-slate-500 hover:text-emerald-600 transition-colors duration-200" href="#">Privacy Policy</a>
                <a class="text-xs text-slate-500 hover:text-emerald-600 transition-colors duration-200" href="#">Terms of Service</a>
                <a class="text-xs text-slate-500 hover:text-emerald-600 transition-colors duration-200" href="#">HIPAA Compliance</a>
                <a class="text-xs text-slate-500 hover:text-emerald-600 transition-colors duration-200" href="#">Contact</a>
            </div>
        </div>
    </footer>

    <!-- Background Cinematic Texture -->
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
        <div class="absolute top-1/4 -left-20 w-96 h-96 bg-primary/5 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-1/4 -right-20 w-[500px] h-[500px] bg-secondary/5 rounded-full blur-[150px]"></div>
    </div>
</body>
</html>
