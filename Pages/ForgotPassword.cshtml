@page
@{
    Layout = null;
    ViewData["Title"] = "Forgot Password";
}

<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        .signature-texture { background: linear-gradient(135deg, #3d6846 0%, #7ca982 100%); }
    </style>
</head>
<body class="bg-[#f7f9fb] font-sans antialiased min-h-screen flex items-center justify-center p-6">
    <div class="w-full max-w-md bg-white rounded-2xl shadow-xl p-8">
        <h1 class="text-2xl font-bold text-slate-800 mb-2">Reset Password</h1>
        <p class="text-slate-500 mb-8 text-sm">Enter your healthcare ID or email to receive a password reset link.</p>
        
        <form>
            <div class="mb-6">
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Email Address</label>
                <input type="email" class="w-full px-4 py-3 rounded-lg bg-slate-50 border border-slate-200 focus:outline-none focus:ring-2 focus:ring-[#7ca982]" placeholder="dr.smith@hospital.com" />
            </div>
            
            <button type="button" class="w-full signature-texture text-white font-bold py-3 rounded-xl shadow-lg hover:opacity-90 transition-opacity" onclick="alert('Password reset link sent to your email!')">
                Send Reset Link
            </button>
        </form>
        
        <div class="mt-6 text-center">
            <a asp-page="/Login" class="text-sm text-[#3d6846] font-semibold hover:underline">Back to Login</a>
        </div>
    </div>
</body>
</html>
