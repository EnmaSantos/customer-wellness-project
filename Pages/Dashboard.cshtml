@page
@model customer_wellness_project.Pages.DashboardModel
@{
    Layout = null;
    ViewData["Title"] = "WellnessOps Dashboard";
}

<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/animejs/3.2.1/anime.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "tertiary-fixed-dim": "#b7c8e1",
                        "secondary-container": "#d5e3fd",
                        "inverse-surface": "#2d3133",
                        "on-primary-fixed": "#00210b",
                        "on-secondary-fixed-variant": "#3a485c",
                        "primary": "#3d6846",
                        "surface-container-high": "#e6e8ea",
                        "on-error": "#ffffff",
                        "background": "#f7f9fb",
                        "on-primary-container": "#133d20",
                        "primary-container": "#7ca982",
                        "secondary-fixed-dim": "#b9c7e0",
                        "tertiary": "#505f76",
                        "secondary-fixed": "#d5e3fd",
                        "tertiary-fixed": "#d3e4fe",
                        "on-surface": "#191c1e",
                        "on-tertiary-fixed": "#0b1c30",
                        "on-error-container": "#93000a",
                        "primary-fixed": "#bfeec3",
                        "surface-bright": "#f7f9fb",
                        "error": "#ba1a1a",
                        "surface": "#f7f9fb",
                        "on-secondary-container": "#57657b",
                        "on-tertiary-fixed-variant": "#38485d",
                        "secondary": "#515f74",
                        "surface-container-low": "#f2f4f6",
                        "outline-variant": "#c1c9bf",
                        "outline": "#727970",
                        "on-primary": "#ffffff",
                        "tertiary-container": "#8f9fb8",
                        "inverse-primary": "#a3d2a8",
                        "primary-fixed-dim": "#a3d2a8",
                        "on-surface-variant": "#414941",
                        "on-primary-fixed-variant": "#254f30",
                        "surface-container": "#eceef0",
                        "surface-dim": "#d8dadc",
                        "on-background": "#191c1e",
                        "on-secondary": "#ffffff",
                        "on-tertiary-container": "#26364b",
                        "inverse-on-surface": "#eff1f3",
                        "on-tertiary": "#ffffff",
                        "surface-tint": "#3d6846",
                        "on-secondary-fixed": "#0d1c2f",
                        "surface-container-lowest": "#ffffff",
                        "error-container": "#ffdad6",
                        "surface-variant": "#e0e3e5",
                        "surface-container-highest": "#e0e3e5"
                    },
                    fontFamily: {
                        "headline": ["Inter", "sans-serif"],
                        "body": ["Inter", "sans-serif"],
                        "label": ["Inter", "sans-serif"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "1rem", "xl": "1.5rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
        .bento-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            grid-auto-rows: minmax(180px, auto);
            gap: 1.5rem;
        }
        .glass-nav {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
        }
        .tonal-shift-layering {
            background-color: #f2f4f6;
        }
        .card-lift {
            transition: transform 0.7s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.7s cubic-bezier(0.2, 0.8, 0.2, 1);
        }
        .card-lift:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(51, 65, 85, 0.04);
        }
        .btn-kinetic:active {
            transform: scale(0.96);
        }
    </style>
</head>
<body class="bg-surface font-body text-on-surface antialiased">
    <!-- SideNavBar -->
    <aside class="fixed left-0 top-0 h-full z-40 flex flex-col w-64 border-r border-slate-200/50 bg-slate-50 font-['Inter'] antialiased text-sm font-medium tracking-tight shadow-[0_20px_40px_rgba(51,65,85,0.04)]">
        <div class="p-8">
            <h1 class="text-xl font-bold text-slate-900 tracking-tight">WellnessOps</h1>
            <p class="text-xs text-slate-500 font-normal mt-1">Enterprise Portal</p>
        </div>
        <nav class="flex-1 px-4 space-y-2">
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg bg-emerald-50 text-emerald-800 font-semibold border-r-4 border-emerald-600 transition-all duration-300" asp-page="/Dashboard">
                <span class="material-symbols-outlined">dashboard</span>
                <span>Dashboard</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-500 hover:text-slate-900 hover:bg-slate-100 transition-all duration-300" href="#">
                <span class="material-symbols-outlined">inventory_2</span>
                <span>Inventory</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-500 hover:text-slate-900 hover:bg-slate-100 transition-all duration-300" href="#">
                <span class="material-symbols-outlined">confirmation_number</span>
                <span>Tickets</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg text-slate-500 hover:text-slate-900 hover:bg-slate-100 transition-all duration-300" href="#">
                <span class="material-symbols-outlined">settings</span>
                <span>Settings</span>
            </a>
        </nav>
        <div class="p-6 mt-auto">
            <a asp-page="/UserProfile" class="flex items-center gap-3 p-3 rounded-xl bg-white shadow-sm hover:shadow-md transition-shadow">
                <img alt="User profile picture" class="w-10 h-10 rounded-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBEOhONain8Tado_9WsuSaI2f1eiE5I4pWd9ATQ4z7mUSqw0rvNDF4RH3uzfoaDC6Ns2vHk8VLDLmw0LW1sFWV6o45dWy57IwmL86c-WgtjkXwlUCdsud58XKdPaceBn5A0wvxVu5d0REuCJJXAL8-e1gg9frD9rV7qbYef9oDtzYLXg0KTdc8K7nQ_c9FAw_kKM5b6u0hQxo71KIAXzWL_ZRhUltk6nZNXUCculAitBxbwv6SOc0ClfzNhEzttgKmtyn3fxYQG6zbE" />
                <div class="overflow-hidden">
                    <p class="text-sm font-bold truncate">Dr. Sarah Chen</p>
                    <p class="text-xs text-slate-500 truncate">Administrator</p>
                </div>
            </a>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main class="ml-64 min-h-screen">
        <!-- TopNavBar -->
        <header class="sticky top-0 right-0 z-30 flex items-center justify-between px-8 w-full h-16 bg-white/80 backdrop-blur-md border-b border-slate-100 font-['Inter'] text-sm font-medium">
            <div class="flex items-center flex-1 max-w-xl">
                <div class="relative w-full focus-within:ring-2 focus-within:ring-emerald-500/20 rounded-lg transition-all">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">search</span>
                    <input class="w-full pl-10 pr-4 py-2 bg-surface-container-high border-none rounded-lg text-sm focus:ring-0 placeholder:text-slate-400" placeholder="Search medical records, inventory, or tickets..." type="text" />
                </div>
            </div>
            <div class="flex items-center gap-6 ml-8">
                <button class="text-slate-500 hover:text-emerald-600 transition-colors relative">
                    <span class="material-symbols-outlined">notifications</span>
                    <span class="absolute top-0 right-0 w-2 h-2 bg-error rounded-full border-2 border-white"></span>
                </button>
                <button class="text-slate-500 hover:text-emerald-600 transition-colors">
                    <span class="material-symbols-outlined">help_outline</span>
                </button>
                <div class="h-8 w-[1px] bg-slate-200"></div>
                <div class="flex items-center gap-2">
                    <span class="text-xs font-bold uppercase tracking-wider text-slate-400">Status</span>
                    <span class="flex items-center gap-1.5 px-2.5 py-1 bg-emerald-100 text-emerald-800 rounded-full text-[10px] font-bold">
                        <span class="w-1.5 h-1.5 bg-emerald-600 rounded-full animate-pulse"></span>
                        LIVE
                    </span>
                </div>
            </div>
        </header>

        <!-- Bento Grid Stage -->
        <div class="p-10 max-w-7xl mx-auto">
            <!-- Page Header -->
            <div class="mb-10 flex justify-between items-end">
                <div>
                    <span class="text-[0.75rem] font-bold uppercase tracking-[0.05em] text-secondary mb-2 block">Executive Summary</span>
                    <h2 class="text-[2.5rem] font-bold tracking-tight text-on-surface">Wellness Dashboard</h2>
                </div>
                <div class="flex gap-3">
                    <button class="px-5 py-2.5 rounded-xl text-sm font-semibold text-secondary bg-surface-container-lowest border border-outline-variant/20 shadow-sm hover:bg-surface-container transition-all btn-kinetic">
                        Generate Report
                    </button>
                    <button class="px-5 py-2.5 rounded-xl text-sm font-semibold text-white bg-gradient-to-br from-primary to-primary-container shadow-md hover:shadow-lg transition-all btn-kinetic flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">add</span>
                        New Entry
                    </button>
                </div>
            </div>

            <div class="bento-grid">
                <!-- 1. Hero Card (Span 2 columns) -->
                <div class="col-span-2 row-span-1 bg-surface-container-lowest rounded-lg p-8 card-lift flex flex-col justify-between relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-64 h-64 bg-primary-fixed-dim/20 rounded-full -mr-20 -mt-20 blur-3xl"></div>
                    <div class="relative z-10">
                        <h3 class="text-2xl font-bold text-on-surface mb-2">Good Morning, Dr. Chen.</h3>
                        <p class="text-on-surface-variant font-medium text-lg max-w-md">You have <span class="text-primary font-bold">14 open tickets</span> that require your immediate clinical attention today.</p>
                    </div>
                    <div class="mt-8 flex gap-4 relative z-10">
                        <button class="bg-primary text-white px-6 py-3 rounded-xl font-semibold btn-kinetic flex items-center gap-2 shadow-lg shadow-primary/20">
                            Review Tickets
                            <span class="material-symbols-outlined">arrow_forward</span>
                        </button>
                    </div>
                </div>

                <!-- 2. Stat Card: Low Stock Items -->
                <div class="col-span-1 bg-surface-container-lowest rounded-lg p-6 card-lift flex flex-col">
                    <div class="flex justify-between items-start mb-4">
                        <div class="p-2 bg-error-container text-on-error-container rounded-lg">
                            <span class="material-symbols-outlined">inventory_2</span>
                        </div>
                        <span class="text-4xl font-extrabold text-error">5</span>
                    </div>
                    <h4 class="text-sm font-bold uppercase tracking-wider text-secondary mb-4">Low Stock Items</h4>
                    <ul class="space-y-3">
                        <li class="flex items-center justify-between text-sm">
                            <span class="text-on-surface-variant">Insulin Humalog</span>
                            <span class="font-bold text-error">2 units</span>
                        </li>
                        <li class="flex items-center justify-between text-sm">
                            <span class="text-on-surface-variant">Nitrate Strips</span>
                            <span class="font-bold text-error">12 units</span>
                        </li>
                        <li class="flex items-center justify-between text-sm">
                            <span class="text-on-surface-variant">Surgical Masks</span>
                            <span class="font-bold text-error">4 boxes</span>
                        </li>
                    </ul>
                </div>

                <!-- 3. Stat Card: Tickets Resolved -->
                <div class="col-span-1 bg-surface-container-lowest rounded-lg p-6 card-lift flex flex-col items-center justify-center text-center">
                    <div class="relative w-32 h-32 mb-4">
                        <svg class="w-full h-full transform -rotate-90">
                            <circle class="text-surface-container" cx="64" cy="64" fill="transparent" r="58" stroke="currentColor" stroke-width="8"></circle>
                            <circle class="text-primary-container rounded-full" cx="64" cy="64" fill="transparent" r="58" stroke="currentColor" stroke-dasharray="364.4" stroke-dashoffset="65.6" stroke-width="8"></circle>
                        </svg>
                        <div class="absolute inset-0 flex items-center justify-center">
                            <span class="text-2xl font-extrabold text-on-surface">82%</span>
                        </div>
                    </div>
                    <h4 class="text-sm font-bold uppercase tracking-wider text-secondary">Tickets Resolved</h4>
                    <p class="text-xs text-on-surface-variant mt-1">+12% from last week</p>
                </div>

                <!-- 4. List Card: Recent Activity (Span 2 rows) -->
                <div class="col-span-1 row-span-2 bg-surface-container-lowest rounded-lg p-6 card-lift overflow-hidden flex flex-col">
                    <h4 class="text-sm font-bold uppercase tracking-wider text-secondary mb-6">Recent Activity</h4>
                    <div class="space-y-6 flex-1 overflow-y-auto pr-2">
                        <div class="flex gap-4 relative">
                            <div class="absolute left-4 top-8 bottom-0 w-[1px] bg-slate-100"></div>
                            <div class="w-8 h-8 rounded-full bg-emerald-100 text-emerald-700 flex items-center justify-center flex-shrink-0 z-10">
                                <span class="material-symbols-outlined text-sm">check_circle</span>
                            </div>
                            <div>
                                <p class="text-sm font-semibold">Ticket #842 Resolved</p>
                                <p class="text-xs text-on-surface-variant">Lab results uploaded to Patient Portal</p>
                                <p class="text-[10px] text-slate-400 mt-1 uppercase">2 mins ago</p>
                            </div>
                        </div>
                        <div class="flex gap-4 relative">
                            <div class="absolute left-4 top-8 bottom-0 w-[1px] bg-slate-100"></div>
                            <div class="w-8 h-8 rounded-full bg-blue-100 text-blue-700 flex items-center justify-center flex-shrink-0 z-10">
                                <span class="material-symbols-outlined text-sm">inventory</span>
                            </div>
                            <div>
                                <p class="text-sm font-semibold">Stock Reorder</p>
                                <p class="text-xs text-on-surface-variant">Automated order placed for Nitrile Gloves</p>
                                <p class="text-[10px] text-slate-400 mt-1 uppercase">45 mins ago</p>
                            </div>
                        </div>
                        <div class="flex gap-4 relative">
                            <div class="absolute left-4 top-8 bottom-0 w-[1px] bg-slate-100"></div>
                            <div class="w-8 h-8 rounded-full bg-orange-100 text-orange-700 flex items-center justify-center flex-shrink-0 z-10">
                                <span class="material-symbols-outlined text-sm">priority_high</span>
                            </div>
                            <div>
                                <p class="text-sm font-semibold">New Urgent Ticket</p>
                                <p class="text-xs text-on-surface-variant">Emergency room equipment maintenance</p>
                                <p class="text-[10px] text-slate-400 mt-1 uppercase">1 hour ago</p>
                            </div>
                        </div>
                        <div class="flex gap-4 relative">
                            <div class="w-8 h-8 rounded-full bg-slate-100 text-slate-700 flex items-center justify-center flex-shrink-0 z-10">
                                <span class="material-symbols-outlined text-sm">person</span>
                            </div>
                            <div>
                                <p class="text-sm font-semibold">Shift Handover</p>
                                <p class="text-xs text-on-surface-variant">Nurse Roberts checked in for evening shift</p>
                                <p class="text-[10px] text-slate-400 mt-1 uppercase">3 hours ago</p>
                            </div>
                        </div>
                    </div>
                    <button class="mt-6 text-primary text-xs font-bold uppercase tracking-widest hover:underline text-center w-full">View Full Audit Log</button>
                </div>

                <!-- 5. Action Card: Quick Links -->
                <div class="col-span-2 bg-surface-container-lowest rounded-lg p-8 card-lift">
                    <h4 class="text-sm font-bold uppercase tracking-wider text-secondary mb-6">Quick Navigation</h4>
                    <div class="grid grid-cols-3 gap-4">
                        <button class="flex flex-col items-center gap-3 p-4 rounded-xl hover:bg-surface-container-low transition-colors group">
                            <div class="w-12 h-12 rounded-full bg-tertiary-fixed text-on-tertiary-fixed flex items-center justify-center group-hover:scale-110 transition-transform">
                                <span class="material-symbols-outlined">analytics</span>
                            </div>
                            <span class="text-xs font-semibold">Analytics</span>
                        </button>
                        <button class="flex flex-col items-center gap-3 p-4 rounded-xl hover:bg-surface-container-low transition-colors group">
                            <div class="w-12 h-12 rounded-full bg-primary-fixed text-on-primary-fixed flex items-center justify-center group-hover:scale-110 transition-transform">
                                <span class="material-symbols-outlined">group</span>
                            </div>
                            <span class="text-xs font-semibold">Staffing</span>
                        </button>
                        <button class="flex flex-col items-center gap-3 p-4 rounded-xl hover:bg-surface-container-low transition-colors group">
                            <div class="w-12 h-12 rounded-full bg-secondary-fixed text-on-secondary-fixed flex items-center justify-center group-hover:scale-110 transition-transform">
                                <span class="material-symbols-outlined">local_hospital</span>
                            </div>
                            <span class="text-xs font-semibold">Clinics</span>
                        </button>
                    </div>
                </div>

                <!-- Wellness Pulse Card -->
                <div class="col-span-1 bg-gradient-to-br from-primary to-primary-container rounded-lg p-6 flex flex-col justify-between text-white card-lift">
                    <span class="material-symbols-outlined text-3xl opacity-50" style="font-variation-settings: 'FILL' 1;">spa</span>
                    <div>
                        <p class="text-xs font-medium opacity-80 uppercase tracking-widest mb-1">Wellness Pulse</p>
                        <p class="text-xl font-bold italic">"Precision in care, warmth in service."</p>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Floating Action Button -->
    <button class="fixed bottom-8 right-8 w-14 h-14 bg-primary text-white rounded-full shadow-2xl flex items-center justify-center hover:scale-110 active:scale-95 transition-all z-50">
        <span class="material-symbols-outlined text-3xl">add</span>
    </button>
    <script src="~/js/site.js"></script>
</body>
</html>
