@page
@model customer_wellness_project.Pages.DashboardModel
@{
    Layout = "_PortalLayout";
    ViewData["Title"] = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
}

<div class="mb-10 flex justify-between items-end animate-[fade-in_0.3s_ease-out]">
    <div>
        <span class="text-[0.75rem] font-bold uppercase tracking-[0.05em] text-[#515f74] mb-2 block">Executive Summary</span>
        <h2 class="text-[2.5rem] font-bold tracking-tight text-slate-800">Wellness Dashboard</h2>
    </div>
    <div class="flex gap-3">
        <button onclick="showToast('Report Generated', 'Your PDF executive report is ready for download.', 'picture_as_pdf')" class="px-5 py-2.5 rounded-xl text-sm font-semibold text-[#515f74] bg-white border border-slate-200 shadow-sm hover:bg-slate-50 transition-all btn-kinetic">
            Generate Report
        </button>
        <button onclick="showToast('New Entity', 'The clinical entry wizard is loading...', 'add_box')" class="px-5 py-2.5 rounded-xl text-sm font-semibold text-white bg-gradient-to-br from-[#3d6846] to-[#7ca982] shadow-md hover:shadow-lg transition-all btn-kinetic flex items-center gap-2">
            <span class="material-symbols-outlined text-sm">add</span>
            New Entry
        </button>
    </div>
</div>

<div class="bento-grid animate-[fade-in-up_0.5s_ease-out]">
    <!-- 1. Hero Card -->
    <div class="col-span-2 row-span-1 bg-white border border-slate-100 rounded-lg p-8 card-lift flex flex-col justify-between relative overflow-hidden shadow-sm">
        <div class="absolute top-0 right-0 w-64 h-64 bg-[#bfeec3]/20 rounded-full -mr-20 -mt-20 blur-3xl"></div>
        <div class="relative z-10">
            <h3 class="text-2xl font-bold text-slate-800 mb-2">Good Morning, Dr. Chen.</h3>
            <p class="text-slate-600 font-medium text-lg max-w-md">You have <span class="text-[#3d6846] font-bold">@Model.OpenTicketsCount open clinical tickets</span> that require your immediate attention today.</p>
        </div>
        <div class="mt-8 flex gap-4 relative z-10">
            <a asp-page="/Tickets" class="bg-[#3d6846] text-white px-6 py-3 rounded-xl font-semibold btn-kinetic flex items-center gap-2 shadow-lg shadow-[#3d6846]/20 inline-flex hover:bg-[#254f30] transition-colors">
                Review Tickets
                <span class="material-symbols-outlined">arrow_forward</span>
            </a>
        </div>
    </div>

    <!-- 2. Stat Card: Low Stock Items -->
    <a asp-page="/Inventory" class="col-span-1 bg-white border border-slate-100 rounded-lg p-6 card-lift flex flex-col cursor-pointer hover:ring-2 hover:ring-[#bfeec3] transition-all shadow-sm">
        <div class="flex justify-between items-start mb-4">
            <div class="p-2 bg-red-50 text-red-700 rounded-lg">
                <span class="material-symbols-outlined">inventory_2</span>
            </div>
            <span class="text-4xl font-extrabold text-red-600">@Model.LowStockProducts.Count</span>
        </div>
        <h4 class="text-sm font-bold uppercase tracking-wider text-slate-500 mb-4">Low Stock Alerts</h4>
        <ul class="space-y-3">
            @if(Model.LowStockProducts.Any())
            {
                foreach(var p in Model.LowStockProducts)
                {
                    <li class="flex items-center justify-between text-sm">
                        <span class="text-slate-600 truncate max-w-[120px]">@p.Name</span>
                        <span class="font-bold text-red-600">@p.StockQuantity units</span>
                    </li>
                }
            }
            else
            {
                <li class="text-sm text-emerald-600 font-medium italic mt-2">All inventory levels optimal.</li>
            }
        </ul>
    </a>

    <!-- 3. Stat Card: Tickets Resolved -->
    <a asp-page="/Tickets" class="col-span-1 bg-white border border-slate-100 rounded-lg p-6 card-lift flex flex-col items-center justify-center text-center cursor-pointer shadow-sm hover:ring-2 hover:ring-[#bfeec3] transition-all">
        <div class="relative w-32 h-32 mb-4">
            <svg class="w-full h-full transform -rotate-90">
                <circle class="text-slate-100" cx="64" cy="64" fill="transparent" r="58" stroke="currentColor" stroke-width="8"></circle>
                <circle class="text-[#7ca982] rounded-full" cx="64" cy="64" fill="transparent" r="58" stroke="currentColor" stroke-dasharray="364.4" stroke-dashoffset="@(364.4 - (364.4 * Model.ResolutionRatePercentage / 100.0))" stroke-width="8" style="transition: stroke-dashoffset 1s ease-in-out;"></circle>
            </svg>
            <div class="absolute inset-0 flex items-center justify-center">
                <span class="text-2xl font-extrabold text-slate-800">@Model.ResolutionRatePercentage%</span>
            </div>
        </div>
        <h4 class="text-sm font-bold uppercase tracking-wider text-slate-500">Tickets Resolved</h4>
        <p class="text-xs text-emerald-600 mt-1 font-medium">System Metrics</p>
    </a>

    <!-- 4. List Card: Recent Activity -->
    <div class="col-span-1 row-span-2 bg-white border border-slate-100 rounded-lg p-6 card-lift overflow-hidden flex flex-col shadow-sm">
        <h4 class="text-sm font-bold uppercase tracking-wider text-slate-500 mb-6">Recent Tickets</h4>
        <div class="space-y-6 flex-1 overflow-y-auto pr-2">
            @if(Model.RecentTickets.Any())
            {
                foreach(var t in Model.RecentTickets)
                {
                    var iconColor = t.Status == "Open" ? "bg-orange-50 text-orange-600" : t.Status == "Resolved" ? "bg-emerald-50 text-emerald-600" : "bg-blue-50 text-blue-600";
                    var iconName = t.Status == "Open" ? "priority_high" : t.Status == "Resolved" ? "check_circle" : "pending";
                    
                    <div class="flex gap-4 relative group cursor-pointer" onclick="showToast('Ticket Preview', '@Html.Raw(t.Description.Replace("'", "\\'"))', 'visibility')">
                        <div class="hidden absolute left-4 top-8 bottom-[-24px] w-[1px] bg-slate-100 group-last:hidden"></div>
                        <div class="w-8 h-8 rounded-full @iconColor flex items-center justify-center flex-shrink-0 z-10 border border-white">
                            <span class="material-symbols-outlined text-sm">@iconName</span>
                        </div>
                        <div>
                            <p class="text-sm font-semibold truncate max-w-[180px]">@t.Title</p>
                            <p class="text-[10px] text-slate-400 mt-1 uppercase">@((DateTime.UtcNow - t.CreatedAt).Days > 0 ? $"{(DateTime.UtcNow - t.CreatedAt).Days} days ago" : "Today")</p>
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="text-sm text-slate-400 italic">No recent activity found.</p>
            }
        </div>
        <button onclick="showToast('Audit Log', 'Connecting to Security Audit Service...', 'security')" class="mt-6 text-[#3d6846] text-xs font-bold uppercase tracking-widest hover:underline text-center w-full">View Full Audit Log</button>
    </div>

    <!-- 5. Action Card: Quick Links -->
    <div class="col-span-2 bg-white border border-slate-100 rounded-lg p-8 card-lift shadow-sm">
        <h4 class="text-sm font-bold uppercase tracking-wider text-slate-500 mb-6">Quick Navigation</h4>
        <div class="grid grid-cols-3 gap-4">
            <button onclick="showToast('Analytics', 'Loading clinical analytics engine...', 'sync')" class="flex flex-col items-center gap-3 p-4 rounded-xl hover:bg-slate-50 transition-colors group">
                <div class="w-12 h-12 rounded-full bg-slate-100 text-slate-600 flex items-center justify-center group-hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined">analytics</span>
                </div>
                <span class="text-xs font-semibold text-slate-700">Analytics</span>
            </button>
            <button onclick="showToast('Staffing', 'Loading EHR schedule matrix...', 'calendar_month')" class="flex flex-col items-center gap-3 p-4 rounded-xl hover:bg-slate-50 transition-colors group">
                <div class="w-12 h-12 rounded-full bg-emerald-50 text-emerald-700 flex items-center justify-center group-hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined">group</span>
                </div>
                <span class="text-xs font-semibold text-slate-700">Staffing</span>
            </button>
            <button onclick="showToast('Clinics', 'Connecting to remote facility monitors...', 'sensors')" class="flex flex-col items-center gap-3 p-4 rounded-xl hover:bg-slate-50 transition-colors group">
                <div class="w-12 h-12 rounded-full bg-blue-50 text-blue-700 flex items-center justify-center group-hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined">local_hospital</span>
                </div>
                <span class="text-xs font-semibold text-slate-700">Clinics</span>
            </button>
        </div>
    </div>

    <!-- Wellness Pulse Card -->
    <div class="col-span-1 bg-gradient-to-br from-[#3d6846] to-[#7ca982] rounded-lg p-6 flex flex-col justify-between text-white card-lift shadow-sm">
        <span class="material-symbols-outlined text-3xl opacity-50" style="font-variation-settings: 'FILL' 1;">spa</span>
        <div>
            <p class="text-xs font-medium opacity-80 uppercase tracking-widest mb-1">Wellness Pulse</p>
            <p class="text-xl font-bold italic">"Precision in care, warmth in service."</p>
        </div>
    </div>
</div>

<style>
    @@keyframes fade-in { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes fade-in-up { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
</style>
