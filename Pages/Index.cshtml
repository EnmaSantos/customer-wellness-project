@page
@model customer_wellness_project.Pages.IndexModel
@{
    Layout = null;
    ViewData["Title"] = "WellnessOps | Clinical Warmth Enterprise Portal";
}

<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "surface": "#f7f9fb",
                        "on-secondary-fixed": "#0d1c2f",
                        "error-container": "#ffdad6",
                        "on-error": "#ffffff",
                        "on-tertiary-container": "#26364b",
                        "on-error-container": "#93000a",
                        "on-tertiary-fixed": "#0b1c30",
                        "inverse-primary": "#a3d2a8",
                        "tertiary-fixed": "#d3e4fe",
                        "error": "#ba1a1a",
                        "on-tertiary-fixed-variant": "#38485d",
                        "outline": "#727970",
                        "surface-container-lowest": "#ffffff",
                        "surface-container-high": "#e6e8ea",
                        "tertiary": "#505f76",
                        "secondary": "#515f74",
                        "primary-fixed": "#bfeec3",
                        "on-primary-fixed-variant": "#254f30",
                        "primary-fixed-dim": "#a3d2a8",
                        "on-surface": "#191c1e",
                        "surface-container-low": "#f2f4f6",
                        "primary-container": "#7ca982",
                        "on-secondary-container": "#57657b",
                        "surface-container": "#eceef0",
                        "tertiary-fixed-dim": "#b7c8e1",
                        "tertiary-container": "#8f9fb8",
                        "outline-variant": "#c1c9bf",
                        "on-tertiary": "#ffffff",
                        "surface-container-highest": "#e0e3e5",
                        "on-primary": "#ffffff",
                        "on-secondary": "#ffffff",
                        "surface-variant": "#e0e3e5",
                        "surface-tint": "#3d6846",
                        "secondary-fixed-dim": "#b9c7e0",
                        "surface-bright": "#f7f9fb",
                        "background": "#f7f9fb",
                        "secondary-container": "#d5e3fd",
                        "primary": "#3d6846",
                        "on-secondary-fixed-variant": "#3a485c",
                        "secondary-fixed": "#d5e3fd",
                        "on-primary-fixed": "#00210b",
                        "inverse-surface": "#2d3133",
                        "on-surface-variant": "#414941",
                        "on-primary-container": "#133d20",
                        "on-background": "#191c1e",
                        "inverse-on-surface": "#eff1f3",
                        "surface-dim": "#d8dadc"
                    },
                    fontFamily: {
                        "headline": ["Inter", "sans-serif"],
                        "body": ["Inter", "sans-serif"],
                        "label": ["Inter", "sans-serif"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "1rem", "xl": "1.5rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        .glass-nav {
            background: rgba(247, 249, 251, 0.8);
            backdrop-filter: blur(20px);
        }
        .kinetic-gradient {
            background: linear-gradient(135deg, #3d6846 0%, #7ca982 100%);
        }
        .bento-card-shadow {
            box-shadow: 0 20px 40px rgba(51, 65, 85, 0.04);
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>
<body class="bg-surface font-body text-on-surface antialiased selection:bg-primary-fixed-dim selection:text-on-primary-fixed">
    <!-- Top Navigation Bar -->
    <nav class="fixed top-0 w-full z-50 glass-nav bg-white/80 shadow-[0_20px_40px_rgba(51,65,85,0.04)] h-16">
        <div class="flex justify-between items-center px-8 h-full max-w-7xl mx-auto">
            <div class="text-xl font-bold text-emerald-900 tracking-tight font-headline">WellnessOps</div>
            <div class="hidden md:flex gap-8 items-center">
                <a class="text-emerald-700 border-b-2 border-emerald-600 font-inter tracking-tight font-semibold text-sm h-16 flex items-center" asp-page="/Index">Dashboard</a>
                <a class="text-slate-500 hover:text-emerald-600 transition-colors duration-300 font-inter tracking-tight font-semibold text-sm" href="#">Health Log</a>
                <a class="text-slate-500 hover:text-emerald-600 transition-colors duration-300 font-inter tracking-tight font-semibold text-sm" href="#">Resources</a>
                <a class="text-slate-500 hover:text-emerald-600 transition-colors duration-300 font-inter tracking-tight font-semibold text-sm" href="#">Support</a>
            </div>
            <div class="flex items-center gap-4">
                <a asp-page="/Login" class="kinetic-gradient text-on-primary px-6 py-2 rounded-xl text-sm font-semibold tracking-tight shadow-md hover:scale-[1.02] active:scale-[0.96] transition-all inline-block">
                    Log In
                </a>
            </div>
        </div>
    </nav>

    <main class="pt-24 pb-20">
        <!-- Hero Section -->
        <section class="max-w-7xl mx-auto px-8 mb-24">
            <div class="flex flex-col lg:flex-row gap-12 items-center">
                <div class="lg:w-1/2">
                    <span class="inline-block px-4 py-1.5 rounded-full bg-primary-fixed text-on-primary-fixed-variant text-[0.75rem] font-bold tracking-widest mb-6 uppercase">Enterprise Clinical Excellence</span>
                    <h1 class="text-[3.5rem] font-bold tracking-tighter leading-[1.1] text-on-surface mb-8 font-headline">
                        Precision care <br /><span class="text-primary">meets human warmth.</span>
                    </h1>
                    <p class="text-[1.125rem] text-on-surface-variant leading-[1.6] mb-10 max-w-lg">
                        Streamline hospital operations with an intuitive clinical portal designed for the modern healthcare enterprise. High-precision logistics, automated through a gentle interface.
                    </p>
                    <div class="flex flex-wrap gap-4">
                        <a asp-page="/Dashboard" class="kinetic-gradient text-on-primary px-8 py-4 rounded-xl font-bold tracking-tight shadow-lg transition-all hover:scale-[1.02] active:scale-[0.96] inline-block">
                            View Admin Dashboard
                        </a>
                        <a asp-page="/Login" class="bg-surface-container-low text-secondary px-8 py-4 rounded-xl font-bold tracking-tight border border-outline-variant/20 transition-all hover:bg-surface-container inline-block">
                            Log In
                        </a>
                    </div>
                </div>
                <div class="lg:w-1/2 relative h-[500px] w-full rounded-xl overflow-hidden bento-card-shadow">
                    <img alt="Modern high-tech hospital laboratory with soft green ambient lighting" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDLlqbY8GS2Aj0oLChXFPqvN6KtWQXrRFya1wfJwAHVt3EI0FAztuxEwOT89inkH1M0ATQ_CxsnSaOh6BoQHQIyK_dKn4xRBbPEa_nHcBeMcbC0cWutOXLpvWGj5Z4U5KVH_gK1ZOhvO32L-1R2R5QnEe0be5EBGXGBYExHoeWpLD2dKoO9BIK2oPFtbESOjAMRYYhaAjBIhvdJ0_8CjO310JJpNHKCzcKqw9JClGXQ72CzB-D2LmwIi1uwn9JH9N1Pa8HX9PhOAG36" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
                </div>
            </div>
        </section>

        <!-- Feature Bento Grid -->
        <section class="max-w-7xl mx-auto px-8">
            <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6 auto-rows-[240px]">
                <!-- Inventory Management - Large -->
                <div class="md:col-span-2 lg:col-span-2 row-span-2 rounded-lg bg-surface-container-lowest p-8 bento-card-shadow flex flex-col justify-between group cursor-pointer transition-all duration-700 cubic-bezier(0.2, 0.8, 0.2, 1) hover:-translate-y-2">
                    <div>
                        <div class="flex items-center gap-3 mb-6">
                            <div class="w-12 h-12 rounded-xl bg-primary-fixed flex items-center justify-center text-primary">
                                <span class="material-symbols-outlined">inventory_2</span>
                            </div>
                            <span class="text-[0.75rem] font-bold tracking-widest text-secondary uppercase">Operational Core</span>
                        </div>
                        <h3 class="text-2xl font-bold tracking-tight text-on-surface mb-4">Inventory Management</h3>
                        <p class="text-on-surface-variant leading-relaxed max-w-md">
                            Real-time tracking of critical clinical assets across multiple facilities with predictive replenishment logic and thermal monitoring.
                        </p>
                    </div>
                    <div class="h-40 w-full bg-surface-container-low rounded-lg mt-6 overflow-hidden relative">
                        <img alt="Clean organized medical storage shelving" class="w-full h-full object-cover opacity-80" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBDkgqV3iHqRk9Z-HzdCjofsyPlquFYvsrNlVIKPBloaP2zRSHshzLZCbFPii20BnJgzRAqDyvlc9VZVKTaI54woFWmc5wXxio3Z9jv5E_FCoHdFL4p9yENpqBye31mEFSD_KjHnuUa7YcW23HYKt44PoETO5DEt5RB71B1CWEdrkorJS6IbH55chA8nFJ0ni7qvYsXarK1h3Ia2WKZzf4rn0pqEUbmUIZPYtE__rf5OxGyhNU2-YzsV0Via_X0GrF04Z0GGbc3hrrh" />
                    </div>
                </div>

                <!-- Support Ticketing -->
                <div class="md:col-span-1 lg:col-span-2 row-span-1 rounded-lg bg-surface-container-lowest p-8 bento-card-shadow flex items-center gap-8 group cursor-pointer transition-all duration-700 cubic-bezier(0.2, 0.8, 0.2, 1) hover:-translate-y-2">
                    <div class="flex-1">
                        <div class="w-10 h-10 rounded-lg bg-secondary-container flex items-center justify-center text-secondary mb-4">
                            <span class="material-symbols-outlined">confirmation_number</span>
                        </div>
                        <h3 class="text-xl font-bold tracking-tight text-on-surface mb-2">Support Ticketing</h3>
                        <p class="text-sm text-on-surface-variant">Instant clinical troubleshooting for frontline staff.</p>
                    </div>
                    <div class="hidden lg:block w-32 h-32 bg-secondary-fixed/30 rounded-full flex items-center justify-center border border-secondary-fixed">
                        <span class="material-symbols-outlined text-4xl text-secondary">support_agent</span>
                    </div>
                </div>

                <!-- Clinical Analytics - Tall -->
                <div class="md:col-span-1 lg:col-span-1 row-span-2 rounded-lg bg-primary-container p-8 bento-card-shadow flex flex-col justify-between group cursor-pointer transition-all duration-700 cubic-bezier(0.2, 0.8, 0.2, 1) hover:-translate-y-2 text-on-primary-container">
                    <div>
                        <div class="w-12 h-12 rounded-xl bg-white/20 flex items-center justify-center mb-8">
                            <span class="material-symbols-outlined text-white">analytics</span>
                        </div>
                        <h3 class="text-2xl font-bold tracking-tight mb-4">Clinical Analytics</h3>
                        <p class="text-sm opacity-90 leading-relaxed">
                            Deep-dive into performance metrics with HIPAA-compliant data visualization and patient outcomes forecasting.
                        </p>
                    </div>
                    <div class="space-y-3">
                        <div class="h-2 bg-white/20 rounded-full w-full">
                            <div class="h-full bg-white rounded-full w-[85%]"></div>
                        </div>
                        <div class="h-2 bg-white/20 rounded-full w-full">
                            <div class="h-full bg-white rounded-full w-[65%]"></div>
                        </div>
                        <div class="h-2 bg-white/20 rounded-full w-full">
                            <div class="h-full bg-white rounded-full w-[92%]"></div>
                        </div>
                    </div>
                </div>

                <!-- Small Grid Item 1 -->
                <div class="md:col-span-1 lg:col-span-1 row-span-1 rounded-lg bg-surface-container-high p-6 flex flex-col justify-center items-center text-center cursor-pointer transition-all duration-700 cubic-bezier(0.2, 0.8, 0.2, 1) hover:bg-surface-container-highest">
                    <span class="material-symbols-outlined text-secondary mb-3 text-3xl">security</span>
                    <p class="font-bold text-sm">HIPAA Compliant</p>
                    <p class="text-xs text-on-surface-variant mt-1">Tier 4 Data Security</p>
                </div>
            </div>
        </section>

        <!-- Social Proof / Trust -->
        <section class="mt-32 max-w-7xl mx-auto px-8 py-16 bg-surface-container-low rounded-xl">
            <div class="text-center mb-12">
                <span class="text-[0.75rem] font-bold tracking-widest text-slate-500 uppercase">Trusted by Global Institutions</span>
            </div>
            <div class="flex flex-wrap justify-around items-center gap-12 opacity-40 grayscale">
                <div class="text-xl font-black font-headline tracking-tighter">MEDIGROUP</div>
                <div class="text-xl font-black font-headline tracking-tighter">SAINT-LUKE'S</div>
                <div class="text-xl font-black font-headline tracking-tighter">QUANTUM HEALTH</div>
                <div class="text-xl font-black font-headline tracking-tighter">NEXUS CLINICAL</div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="mt-32 max-w-5xl mx-auto px-8 text-center pb-16">
            <h2 class="text-[2.5rem] font-bold tracking-tight text-on-surface mb-6">Explore the Portal</h2>
            <p class="text-lg text-on-surface-variant mb-10 max-w-2xl mx-auto">
                Dive into the admin dashboard to see how WellnessOps dynamically manages real-time healthcare logistics.
            </p>
            <div class="inline-flex gap-4 p-2 relative">
                <a asp-page="/Dashboard" class="kinetic-gradient text-on-primary px-10 py-4 rounded-xl font-bold shadow-lg transition-all hover:scale-[1.02] active:scale-[0.95] inline-block">
                    Enter Dashboard
                </a>
            </div>
        </section>
    </main>

    <!-- Footer -->
    <footer class="bg-white w-full border-t-0 mt-auto">
        <div class="max-w-7xl mx-auto px-8 py-12 flex flex-col md:flex-row justify-between items-start md:items-center">
            <div class="mb-8 md:mb-0">
                <div class="font-bold text-slate-900 text-lg mb-2 tracking-tight">WellnessOps</div>
                <p class="font-inter text-xs text-slate-500">&copy; @DateTime.Now.Year WellnessOps Clinical Systems. All rights reserved.</p>
            </div>
            <div class="flex flex-wrap gap-8">
                <a class="text-slate-500 hover:text-emerald-600 transition-colors duration-200 font-inter text-xs" asp-page="/Privacy">Privacy Policy</a>
                <a class="text-slate-500 hover:text-emerald-600 transition-colors duration-200 font-inter text-xs" asp-page="/Privacy">Terms of Service</a>
                <a class="text-slate-500 hover:text-emerald-600 transition-colors duration-200 font-inter text-xs" asp-page="/Privacy">HIPAA Compliance</a>
                <a class="text-slate-500 hover:text-emerald-600 transition-colors duration-200 font-inter text-xs" asp-page="/Privacy">Contact</a>
            </div>
        </div>
    </footer>
</body>
</html>
