@page
@model customer_wellness_project.Pages.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "WellnessOps | Clinical Portal Login";
}

<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "surface": "#f7f9fb",
                        "on-secondary-fixed": "#0d1c2f",
                        "error-container": "#ffdad6",
                        "on-error": "#ffffff",
                        "on-tertiary-container": "#26364b",
                        "on-error-container": "#93000a",
                        "on-tertiary-fixed": "#0b1c30",
                        "inverse-primary": "#a3d2a8",
                        "tertiary-fixed": "#d3e4fe",
                        "error": "#ba1a1a",
                        "on-tertiary-fixed-variant": "#38485d",
                        "outline": "#727970",
                        "surface-container-lowest": "#ffffff",
                        "surface-container-high": "#e6e8ea",
                        "tertiary": "#505f76",
                        "secondary": "#515f74",
                        "primary-fixed": "#bfeec3",
                        "on-primary-fixed-variant": "#254f30",
                        "primary-fixed-dim": "#a3d2a8",
                        "on-surface": "#191c1e",
                        "surface-container-low": "#f2f4f6",
                        "primary-container": "#7ca982",
                        "on-secondary-container": "#57657b",
                        "surface-container": "#eceef0",
                        "tertiary-fixed-dim": "#b7c8e1",
                        "tertiary-container": "#8f9fb8",
                        "outline-variant": "#c1c9bf",
                        "on-tertiary": "#ffffff",
                        "surface-container-highest": "#e0e3e5",
                        "on-primary": "#ffffff",
                        "on-secondary": "#ffffff",
                        "surface-variant": "#e0e3e5",
                        "surface-tint": "#3d6846",
                        "secondary-fixed-dim": "#b9c7e0",
                        "surface-bright": "#f7f9fb",
                        "background": "#f7f9fb",
                        "secondary-container": "#d5e3fd",
                        "primary": "#3d6846",
                        "on-secondary-fixed-variant": "#3a485c",
                        "secondary-fixed": "#d5e3fd",
                        "on-primary-fixed": "#00210b",
                        "inverse-surface": "#2d3133",
                        "on-surface-variant": "#414941",
                        "on-primary-container": "#133d20",
                        "on-background": "#191c1e",
                        "inverse-on-surface": "#eff1f3",
                        "surface-dim": "#d8dadc"
                    },
                    fontFamily: {
                        "headline": ["Inter"],
                        "body": ["Inter"],
                        "label": ["Inter"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .glass-effect {
            background: rgba(247, 249, 251, 0.8);
            backdrop-filter: blur(20px);
        }
        .kinetic-button {
            transition: transform 0.7s cubic-bezier(0.2, 0.8, 0.2, 1);
        }
        .kinetic-button:active {
            transform: scale(0.96);
        }
        .signature-texture {
            background: linear-gradient(135deg, #3d6846 0%, #7ca982 100%);
        }
    </style>
</head>
<body class="bg-surface font-body text-on-surface min-h-screen flex flex-col">
    <!-- TopNavBar Suppression: Login is a Focused Transactional Page -->
    <main class="flex-grow flex items-center justify-center px-6 py-12">
        <div class="w-full max-w-[1000px] grid grid-cols-1 md:grid-cols-12 gap-0 overflow-hidden rounded-lg shadow-[0_20px_40px_rgba(51,65,85,0.04)] bg-surface-container-lowest">
            <!-- Bento Hero Section (Left) -->
            <div class="md:col-span-7 relative hidden md:flex flex-col justify-end p-12 overflow-hidden bg-surface-container">
                <div class="absolute inset-0 z-0">
                    <img class="w-full h-full object-cover opacity-60 mix-blend-multiply grayscale" alt="modern clinical laboratory interior" src="https://lh3.googleusercontent.com/aida-public/AB6AXuADxrNPywxA1mqv5OYHyf1eXqgtOPhYA69C-QoR5dyr9Wy5DLcmvZ3jyx4RqviQYyeNaM0rXEBq74aiHbv57jWKVhTZK52iv5LkQ7hDjujNJx0ekYINOXM5xqJQJxlQR6gc6YEfc47IcN10vFfPlnaaCEsWzwkcNvI0dq89TjsyyFEbIqLwpDzTwWza5UFEmZIc8u1nhf__JnRiDh9N6IC7oRwMW8jIIGZ4mN0zPh2pIsOh5ukeOVuEeX1lVSG3jkY8qduAcLjrdoWz" />
                </div>
                <div class="absolute inset-0 bg-gradient-to-t from-primary/40 to-transparent z-10"></div>
                <div class="relative z-20 space-y-6">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-lg signature-texture flex items-center justify-center text-on-primary">
                            <span class="material-symbols-outlined">clinical_notes</span>
                        </div>
                        <span class="text-xl font-black tracking-tight text-on-primary-container">WellnessOps</span>
                    </div>
                    <h1 class="text-display-lg text-4xl font-bold tracking-tight text-on-primary-container leading-tight">
                        Precision Care <br />Starts Here.
                    </h1>
                    <p class="text-body-md text-on-surface-variant max-w-sm leading-relaxed">
                        Access the next generation of clinical workflow management and patient health logistics.
                    </p>
                    <div class="flex gap-4 pt-4">
                        <div class="p-4 rounded-xl bg-white/40 backdrop-blur-md border border-white/20">
                            <p class="text-[10px] font-bold uppercase tracking-widest text-on-primary-fixed-variant mb-1">Status</p>
                            <p class="text-sm font-semibold flex items-center gap-2">
                                <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
                                Clinical Systems Online
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Login Form Section (Right) -->
            <div class="md:col-span-5 p-8 md:p-12 flex flex-col justify-center">
                <div class="mb-10">
                    <h2 class="text-headline-sm text-2xl font-semibold text-secondary mb-2">Clinical Portal</h2>
                    <p class="text-body-md text-on-surface-variant">Authenticated access for medical practitioners.</p>
                </div>

                <form method="post" class="space-y-6">
                    @Html.AntiForgeryToken()

                    <!-- Healthcare ID Input -->
                    <div class="space-y-2">
                        <label class="text-label-md text-[11px] font-bold uppercase tracking-wider text-secondary flex items-center gap-2">
                            Healthcare ID
                        </label>
                        <div class="relative group">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-outline text-[20px]">badge</span>
                            <input asp-for="HealthcareId" value="schen@wellnessops.com" class="w-full pl-12 pr-4 py-4 bg-surface-container-high rounded-lg border-none focus:ring-2 focus:ring-primary-fixed focus:bg-surface-container-lowest text-on-surface placeholder:text-outline/60 transition-all duration-300" placeholder="WOP-000-000" type="text" />
                        </div>
                    </div>

                    <!-- Password Input -->
                    <div class="space-y-2">
                        <div class="flex justify-between items-center">
                            <label class="text-label-md text-[11px] font-bold uppercase tracking-wider text-secondary">
                                Password
                            </label>
                        </div>
                        <div class="relative group">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-outline text-[20px]">lock</span>
                            <input asp-for="Password" value="Melaleuca2026!" class="w-full pl-12 pr-4 py-4 bg-surface-container-high rounded-lg border-none focus:ring-2 focus:ring-primary-fixed focus:bg-surface-container-lowest text-on-surface placeholder:text-outline/60 transition-all duration-300" placeholder="••••••••" type="password" />
                        </div>
                    </div>

                    <div class="flex items-center justify-between py-2">
                        <label class="flex items-center gap-2 cursor-pointer group">
                            <input asp-for="RememberMe" class="w-4 h-4 rounded-sm border-outline-variant text-primary focus:ring-primary-fixed" type="checkbox" />
                            <span class="text-xs text-on-surface-variant group-hover:text-primary transition-colors">Keep me signed in</span>
                        </label>
                        <a class="text-xs font-semibold text-primary hover:text-primary-container transition-colors" asp-page="/ForgotPassword">Forgot Password?</a>
                    </div>

                    <button class="w-full py-4 rounded-xl signature-texture text-on-primary font-bold text-sm tracking-wide shadow-lg shadow-primary/20 kinetic-button" type="submit">
                        Log In
                    </button>
                </form>

                <div class="mt-12 pt-8 border-t border-surface-container-high">
                    <div class="flex flex-col gap-4">
                        <p class="text-xs text-on-surface-variant flex items-center gap-2">
                            <span class="material-symbols-outlined text-[14px]">info</span>
                            Need credentials for your department? New users can sign up here.
                        </p>
                        <a asp-page="/SignUp" class="w-full py-3 rounded-lg border border-outline-variant/30 text-on-surface-variant font-bold text-xs uppercase tracking-widest hover:bg-surface-container transition-colors text-center block">
                            Sign Up
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="w-full bg-white mt-auto">
        <div class="max-w-7xl mx-auto px-8 py-8 flex flex-col md:flex-row justify-between items-center gap-6">
            <div class="flex flex-col items-center md:items-start gap-1">
                <span class="font-bold text-slate-900 text-sm tracking-tight">WellnessOps Clinical Systems</span>
                <span class="text-[10px] text-slate-500 font-medium uppercase tracking-[0.2em]">&copy; @DateTime.Now.Year All rights reserved.</span>
            </div>
            <div class="flex flex-wrap justify-center gap-8">
                <a class="text-xs text-slate-500 hover:text-emerald-600 transition-colors duration-200" asp-page="/Privacy">Privacy Policy</a>
                <a class="text-xs text-slate-500 hover:text-emerald-600 transition-colors duration-200" asp-page="/Privacy">Terms of Service</a>
                <a class="text-xs text-slate-500 hover:text-emerald-600 transition-colors duration-200" asp-page="/Privacy">HIPAA Compliance</a>
                <a class="text-xs text-slate-500 hover:text-emerald-600 transition-colors duration-200" asp-page="/Privacy">Contact</a>
            </div>
        </div>
    </footer>
</body>
</html>
